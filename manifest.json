{
  "manifest_version": 3,
  "name": "Video Downloader",
  "version": "2.0.0",
  "description": "Download videos from X (Twitter) and Instagram",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["content/platforms/twitter.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.instagram.com/*", "*://instagram.com/*"],
      "js": ["content/platforms/instagram.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabs"
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup/about.html", "icons/apps/twitter.png", "icons/apps/social.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": [
    "*://x.com/*",
    "*://twitter.com/*",
    "*://video.twimg.com/*",
    "*://api.twitter.com/*",
    "*://api.x.com/*",
    "*://cdn.syndication.twimg.com/*",
    "*://api.fxtwitter.com/*",
    "*://www.instagram.com/*",
    "*://instagram.com/*",
    "*://*.cdninstagram.com/*",
    "*://*.fbcdn.net/*"
  ]
}
